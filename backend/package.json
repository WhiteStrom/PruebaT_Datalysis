{
  "name": "backend",
  "version": "1.0.0",
  "description": "Commercial Dashboard Backend - Hexagonal Architecture",
  "main": "dist/web/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/web/server.js",
    "dev": "ts-node -r dotenv/config src/web/server.ts",
    "etl:ingest": "ts-node -r dotenv/config src/scripts/ingest.ts",
    "etl:clean": "ts-node -r dotenv/config src/scripts/clean.ts",
    "etl:gold": "ts-node -r dotenv/config src/scripts/gold.ts",
    "etl:all": "npm run etl:ingest && npm run etl:clean && npm run etl:gold",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "csv-parse": "^6.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ]
  }
}
